# Copy to .env.local and configure the WooCommerce backend.
# Set WC_API_URL to the WordPress/WooCommerce origin (not the storefront domain).
# Keep a single canonical host (either www or non-www) with valid SSL for that origin.

WC_API_URL=https://wp.cosmictees.co.in
NEXT_PUBLIC_WC_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
